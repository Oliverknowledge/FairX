{
  "name": "fairx-fairplay-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Unaudited Solana devnet prototype for selectively refunding stale-price exploit orders using historical TxLINE evidence.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "anchor:build": "anchor build",
    "v4:verify-proofs": "node --import tsx scripts/fairx-v4-verify-proofs.ts",
    "v4:test-lifecycle": "node --import tsx scripts/fairx-v4-litesvm-lifecycle.ts",
    "v4:test-void": "node --import tsx scripts/fairx-v4-void-litesvm.ts",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "test:onchain": "anchor test",
    "test:watch": "vitest",
    "txline:capture": "node --env-file-if-exists=.env.local --import tsx scripts/txline-capture.ts",
    "txline:verify-capture": "node --import tsx scripts/txline-verify-capture.ts",
    "txline:validate": "node --env-file-if-exists=.env.local --import tsx scripts/txline-validate.ts",
    "lineguard:record-proof": "node --import tsx scripts/lineguard-record-proof.ts",
    "lineguard:record-settlement": "node --import tsx scripts/lineguard-record-settlement.ts",
    "lineguard:v2:initialize": "node --env-file-if-exists=.env.local --import tsx scripts/lineguard-v2-initialize.ts",
    "lineguard:v3:record-lifecycle": "node --env-file-if-exists=.env.local --import tsx scripts/lineguard-v3-record-lifecycle.ts",
    "polymarket:discover": "node --env-file-if-exists=.env.local --import tsx scripts/polymarket-discover.ts",
    "polymarket:capture": "node --env-file-if-exists=.env.local --import tsx scripts/polymarket-capture.ts",
    "polymarket:verify-capture": "node --import tsx scripts/polymarket-verify-capture.ts",
    "fairx:prepare-live-market": "node --env-file-if-exists=.env.local --import tsx scripts/fairx-prepare-live-market.ts",
    "fairx:initialize-live-market": "node --env-file-if-exists=.env.local --import tsx scripts/fairx-initialize-live-market.ts"
  },
  "dependencies": {
    "@anchor-lang/core": "1.1.2",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.33",
    "@solana/web3.js": "^1.98.4",
    "bs58": "6.0.0",
    "js-sha256": "0.11.0",
    "lucide-react": "0.475.0",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.8",
    "@types/chai": "4.3.20",
    "@types/mocha": "9.1.1",
    "@types/node": "22.15.0",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "chai": "4.5.0",
    "litesvm": "^1.3.0",
    "mocha": "9.2.2",
    "tailwindcss": "4.1.8",
    "ts-mocha": "10.1.0",
    "tsx": "^4.23.0",
    "typescript": "5.8.3",
    "vitest": "^3.2.7"
  }
}
