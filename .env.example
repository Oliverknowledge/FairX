# Optional on-chain settlement guard.
# Leave unset to run the off-chain sandbox with "On-chain mode not configured."

NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_LINEGUARD_PROGRAM_ID=6k8uu3N8Eedd26be6v96Dfs5H2YrikbhQe7sSz8HWdSe
SOLANA_RPC_URL=https://api.devnet.solana.com

# Server-side only. JSON array or base58-encoded 64-byte secret key for the devnet operator.
# Never expose this with NEXT_PUBLIC_.
# (SOLANA_DEMO_KEYPAIR is still read as a backward-compatible fallback.)
LINEGUARD_OPERATOR_KEYPAIR=

# Required for every legacy server-signed mutation API. Use at least 32 random
# characters and never expose it to browser code. Leave unset to disable those routes.
LINEGUARD_OPERATOR_API_TOKEN=

# Offline-only v3 lifecycle recorder signer paths. The recorder reads these files
# locally and never prints, copies, commits, or sends their secret material. Dedicated
# Wallet A/B/C test keys make their balance deltas independently auditable.
LINEGUARD_FEED_KEYPAIR_FILE=
LINEGUARD_PRICING_KEYPAIR_FILE=
LINEGUARD_RESOLUTION_A_KEYPAIR_FILE=
LINEGUARD_RESOLUTION_B_KEYPAIR_FILE=
FAIRX_WALLET_A_KEYPAIR_FILE=
FAIRX_WALLET_B_KEYPAIR_FILE=
FAIRX_WALLET_C_KEYPAIR_FILE=
LINEGUARD_V3_ORDER_EXPIRY_SLOT=
LINEGUARD_V3_CLOSE_TIME=

# Optional TxLINE integration. Secrets are server-only.
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=
TXLINE_FIXTURE_ID=
TXLINE_NETWORK=devnet
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_RPC_URL=https://api.devnet.solana.com
TXLINE_SCORES_STREAM_PATH=/api/scores/stream
TXLINE_ODDS_STREAM_PATH=/api/odds/stream
TXLINE_SCORES_SNAPSHOT_PATH=/api/scores/snapshot
TXLINE_SCORES_HISTORICAL_PATH=/api/scores/historical
TXLINE_FIXTURES_SNAPSHOT_PATH=/api/fixtures/snapshot
TXLINE_ODDS_SNAPSHOT_PATH=/api/odds/snapshot

# Public build metadata. Vercel normally supplies VERCEL_GIT_COMMIT_SHA automatically.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BUILD_TIME=
NEXT_PUBLIC_COMMIT_SHA=
